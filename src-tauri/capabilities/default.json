{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:webview:allow-on-drag-drop-event",
    "dialog:default",
    "updater:default",
    "process:default",
    "opener:default"
  ]
}
